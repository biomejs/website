{
  "name": "@biomejs/website",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "format": "pnpm biome format --write",
    "check": "pnpm biome check --write",
    "tsc": "astro sync && astro check",
    "build": "NODE_OPTIONS='--max-old-space-size=8192' astro build",
